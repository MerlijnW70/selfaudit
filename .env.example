# Copy this file to `.env` and fill in your values. `.env` is gitignored — never
# commit your real key.

# Your Anthropic API key (https://console.anthropic.com/). Required only for the
# live LLM-validator run: `python -m selfaudit.llmdemo`. The scripted scenarios
# and the test suite do NOT need it.
ANTHROPIC_API_KEY=

# Optional: path to a CA bundle (PEM) to verify TLS against. Needed only behind a
# TLS-intercepting corporate proxy that re-signs HTTPS (Python would otherwise
# raise CERTIFICATE_VERIFY_FAILED). Leave blank to use the system/SDK default.
SSL_CERT_FILE=
